#!/bin/zsh
set -euo pipefail

# Pre-push hook: validate that pushed tags match MARKETING_VERSION.
# To install: git config core.hooksPath .githooks

while read local_ref local_sha remote_ref remote_sha; do
  case "$local_ref" in
    refs/tags/v*)
      tag_version="${local_ref#refs/tags/v}"

      if [[ ! "$tag_version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "Invalid tag format: $local_ref. Expected vX.Y.Z" >&2
        exit 1
      fi

      project_version=$(
        grep -m1 'MARKETING_VERSION' macgit.xcodeproj/project.pbxproj \
          | sed -E 's/.*= ([^;]+);.*/\1/' \
          | tr -d ' '
      )

      if [[ "$tag_version" != "$project_version" ]]; then
        echo "Tag version $tag_version does not match MARKETING_VERSION $project_version in macgit.xcodeproj/project.pbxproj" >&2
        echo "Run: ./scripts/release/prepare-release.sh $tag_version" >&2
        exit 1
      fi
      ;;
  esac
done
